<% layout("/layouts/boilerplate") %>
<body>
    <h3>All Listings</h3>

    <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-2 rpw-cols-sm-1">
        <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem">
                <div class="card-img-overlay"></div>
                <div class = "card-body">
                    <p class = "card-text">
                        <b><%= listing.title %></b> <br />
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
                    </p>        
                </div>
                </div>
            </a>
            
            <% } %>
    </div>

    <ul>
        <% for(let listing of allListings) { %>
        <li>
            <a href="/listings/<%= listing._id %>"> <%= listing.title %> </a>
            <br /><br />
            <!-- Edit Button -->
            <a href="/listings/<%= listing._id %>/edit">
                <button>Edit</button>
            </a>
            
            <!-- Delete Button (form submission) -->
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit">Delete</button>
            </form>
        </li>
        <% } %>
    </ul>
</body>
</html>
